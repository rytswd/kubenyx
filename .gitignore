# Nix build outputs (any `nix build` in the repo drops these GC roots)
result
result-*
.result-*
result-nb

# Test/benchmark run artifacts (local only)
test-*.log
bench-vm-*.log
.test-tmp/

# Rust build artifacts
rust/target/

# MicroVM run logs (local only)
microvm-*.log

# MicroVM control sockets and kubenyx-snap run artifacts
*.sock
resume-console.log
take-console.log
# Anchored: kubenyx-snap's default --out dir at the repo root only —
# unanchored `snapshot/` silently untracked air/v0.1/snapshot/.
/snapshot/

# Fetched per-boot cluster credentials (host-side kubectl)
*.kubeconfig
